<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Universal WIP Intelligence · TSM Sovereign Mesh</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#040810;--surf:#080f1c;--surf2:#0c1525;--b1:rgba(0,229,255,.07);--b2:rgba(0,229,255,.15);
  --cyan:#00e5ff;--green:#00ff88;--amber:#ffb300;--red:#ff4455;--purple:#a855f7;--gold:#f5c842;
  --muted:#2a4a6a;--text:#90b8d8;--white:#e0f0ff;
  --mono:'JetBrains Mono',monospace;--head:'Barlow Condensed',sans-serif;--body:'Barlow',sans-serif;
  /* sector themes */
  --s-color:var(--cyan);
}
body.sector-healthcare{--s-color:#00ff88}
body.sector-insurance{--s-color:#a855f7}
body.sector-construction{--s-color:#ffb300}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--body);font-size:13px;min-height:100vh}

/* TOPBAR */
.tb{position:sticky;top:0;z-index:200;background:rgba(4,8,16,.97);backdrop-filter:blur(12px);border-bottom:1px solid var(--b2);display:flex;align-items:center;justify-content:space-between;padding:.5rem 1.2rem;gap:1rem}
.tb-brand{font-family:var(--mono);font-size:.55rem;letter-spacing:.2em;color:var(--s-color);transition:color .4s}
.tb-nav{display:flex;gap:.3rem;flex-wrap:wrap}
.tb-link{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;color:var(--muted);padding:.28rem .55rem;border:1px solid transparent;text-decoration:none;transition:all .2s;cursor:pointer;background:transparent}
.tb-link:hover{color:var(--s-color);border-color:var(--b2)}
.tb-status{font-family:var(--mono);font-size:.48rem;letter-spacing:.1em;color:var(--green);display:flex;align-items:center;gap:.4rem;flex-shrink:0}
.tb-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}

/* HERO */
.hero{padding:2.5rem 1.2rem 1.5rem;max-width:1200px;margin:0 auto}
.hero-eye{font-family:var(--mono);font-size:.48rem;letter-spacing:.2em;color:var(--s-color);margin-bottom:.8rem;transition:color .4s}
.hero-title{font-family:var(--head);font-size:clamp(2rem,5vw,3.8rem);font-weight:900;color:var(--white);line-height:.92;margin-bottom:.6rem}
.hero-title em{color:var(--s-color);font-style:normal;transition:color .4s}

/* SECTOR SWITCHER */
.sector-bar{display:flex;gap:0;border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:2rem;width:fit-content}
.sector-btn{font-family:var(--mono);font-size:.52rem;letter-spacing:.1em;padding:.45rem 1.1rem;border:none;background:transparent;color:var(--muted);cursor:pointer;border-right:1px solid var(--b2);transition:all .25s;text-transform:uppercase}
.sector-btn:last-child{border-right:none}
.sector-btn.active-construction{background:rgba(255,179,0,.12);color:var(--amber)}
.sector-btn.active-healthcare{background:rgba(0,255,136,.1);color:var(--green)}
.sector-btn.active-insurance{background:rgba(168,85,247,.1);color:var(--purple)}

/* MAIN GRID */
.main{max-width:1200px;margin:0 auto;padding:0 1.2rem 2rem;display:grid;grid-template-columns:1fr 320px;gap:1rem}
@media(max-width:900px){.main{grid-template-columns:1fr}}

/* WIP MATRIX */
.wip-matrix{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.wm-head{background:var(--surf2);padding:.6rem 1rem;border-bottom:1px solid var(--b2);display:flex;justify-content:space-between;align-items:center}
.wm-title{font-family:var(--mono);font-size:.55rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.wm-badge{font-family:var(--mono);font-size:.45rem;letter-spacing:.1em;padding:.15rem .5rem;border:1px solid;border-radius:2px}
.wip-table{width:100%;border-collapse:collapse}
.wip-table th{font-family:var(--mono);font-size:.45rem;letter-spacing:.1em;color:var(--muted);padding:.5rem .8rem;border-bottom:1px solid var(--b1);text-align:left;font-weight:400;text-transform:uppercase}
.wip-table td{padding:.55rem .8rem;border-bottom:1px solid var(--b1);font-size:.72rem}
.wip-table tr:last-child td{border-bottom:none}
.wip-table tr:hover td{background:var(--surf2)}
.cell-label{font-family:var(--mono);font-size:.55rem;color:var(--text)}
.cell-value{font-size:.8rem;font-weight:600;color:var(--white);font-family:var(--mono)}
.cell-pct{font-size:.75rem;font-weight:700;font-family:var(--mono)}
.cell-good{color:var(--green)}
.cell-warn{color:var(--amber)}
.cell-bad{color:var(--red)}
.cell-bar-wrap{width:120px;height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;display:inline-block;vertical-align:middle;margin-left:.5rem}
.cell-bar{height:100%;border-radius:2px;transition:width .6s}
.bar-good{background:var(--green)}
.bar-warn{background:var(--amber)}
.bar-bad{background:var(--red)}

/* WIP CARDS */
.wip-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.75rem;margin-bottom:1rem}
.wc{background:var(--surf);border:1px solid var(--b1);border-radius:4px;padding:.9rem;position:relative;overflow:hidden}
.wc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--s-color);opacity:.6;transition:background .4s}
.wc-label{font-family:var(--mono);font-size:.42rem;letter-spacing:.12em;color:var(--muted);margin-bottom:.3rem}
.wc-value{font-family:var(--head);font-size:1.6rem;font-weight:800;color:var(--white);line-height:1}
.wc-sub{font-family:var(--mono);font-size:.48rem;color:var(--muted);margin-top:.25rem}
.wc-delta{font-family:var(--mono);font-size:.5rem;margin-top:.35rem}
.delta-up{color:var(--green)}
.delta-down{color:var(--red)}
.delta-warn{color:var(--amber)}

/* ALERT FEED */
.alert-feed{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.af-head{background:var(--surf2);padding:.5rem .8rem;border-bottom:1px solid var(--b2);font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.af-item{padding:.5rem .8rem;border-bottom:1px solid var(--b1);display:flex;gap:.6rem;align-items:flex-start}
.af-item:last-child{border-bottom:none}
.af-sev{font-family:var(--mono);font-size:.45rem;letter-spacing:.06em;padding:.1rem .3rem;border:1px solid;flex-shrink:0;margin-top:1px}
.sev-crit{color:var(--red);border-color:var(--red)}
.sev-high{color:var(--amber);border-color:var(--amber)}
.sev-med{color:var(--cyan);border-color:var(--cyan)}
.af-text{font-size:.65rem;color:var(--text);line-height:1.5}
.af-text strong{color:var(--white)}

/* AI NARRATIVE */
.ai-panel{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.ap-head{background:var(--surf2);padding:.55rem .8rem;border-bottom:1px solid var(--b2);display:flex;justify-content:space-between;align-items:center}
.ap-title{font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.ap-run{font-family:var(--mono);font-size:.48rem;letter-spacing:.08em;padding:.28rem .7rem;background:var(--s-color);color:#040810;border:none;cursor:pointer;font-weight:700;transition:opacity .2s}
.ap-run:hover{opacity:.85}
.ap-run:disabled{opacity:.4;cursor:not-allowed}
.ap-body{padding:.7rem .8rem;min-height:120px;font-size:.68rem;color:var(--text);line-height:1.7;white-space:pre-wrap;font-family:var(--mono)}
.ap-placeholder{color:var(--muted);font-style:italic}

/* ACTION RAIL */
.action-rail{background:var(--surf);border:1px solid var(--b2);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.ar-head{background:var(--surf2);padding:.5rem .8rem;border-bottom:1px solid var(--b2);font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;color:var(--s-color);transition:color .4s}
.ar-btn{display:block;width:100%;text-align:left;padding:.55rem .8rem;border:none;border-bottom:1px solid var(--b1);background:transparent;color:var(--text);font-size:.68rem;cursor:pointer;font-family:var(--body);transition:all .2s}
.ar-btn:last-child{border-bottom:none}
.ar-btn:hover{background:var(--surf2);color:var(--white)}
.ar-btn::before{content:'⚡ ';color:var(--s-color);font-size:.55rem;transition:color .4s}

/* SCHEMA VIEWER */
.schema-panel{background:var(--surf);border:1px solid var(--b1);border-radius:4px;overflow:hidden;margin-bottom:1rem}
.sp-head{background:var(--surf2);padding:.5rem .8rem;border-bottom:1px solid var(--b1);font-family:var(--mono);font-size:.5rem;letter-spacing:.12em;color:var(--muted)}
.sp-body{padding:.6rem .8rem;font-family:var(--mono);font-size:.6rem;color:var(--text);line-height:1.7;overflow-x:auto;max-height:200px;overflow-y:auto}
.sp-key{color:var(--cyan)}
.sp-val{color:var(--green)}
.sp-num{color:var(--amber)}
.sp-str{color:var(--purple)}

/* SECTOR ENTITIES */
.entity-list{display:flex;flex-direction:column;gap:.5rem;margin-bottom:1rem}
.entity{background:var(--surf);border:1px solid var(--b1);border-radius:4px;padding:.7rem .9rem;cursor:pointer;transition:all .2s;border-left:3px solid var(--b1)}
.entity.selected{border-left-color:var(--s-color);background:var(--surf2)}
.entity:hover{border-left-color:var(--b2)}
.entity-id{font-family:var(--mono);font-size:.5rem;letter-spacing:.1em;color:var(--muted)}
.entity-name{font-size:.78rem;font-weight:600;color:var(--white);margin:.15rem 0}
.entity-meta{font-family:var(--mono);font-size:.48rem;color:var(--muted)}
.entity-risk{float:right;font-family:var(--mono);font-size:.65rem;font-weight:700}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
@keyframes stream{from{opacity:0;transform:translateY(2px)}to{opacity:1;transform:none}}
.streaming .ap-body span{animation:stream .1s ease forwards}
</style>
</head>
<body class="sector-construction">

<!-- TOPBAR -->
<div class="tb">
  <div class="tb-brand" id="tb-brand">TSM · SOVEREIGN MESH · WIP INTELLIGENCE</div>
  <nav class="tb-nav">
    <a class="tb-link" href="/construction-suite/construction-pro.html">CONSTRUCTION ↗</a>
    <a class="tb-link" href="/finops-suite/financial-ui.html">FINOPS ↗</a>
    <a class="tb-link" href="/healthcare/index.html">HEALTHCARE ↗</a>
  </nav>
  <div class="tb-status"><div class="tb-dot"></div><span id="tb-status-text">SOVEREIGN MESH ONLINE</span></div>
</div>

<!-- HERO + SECTOR SWITCHER -->
<div style="max-width:1200px;margin:0 auto;padding:2rem 1.2rem 0">
  <div class="hero-eye" id="hero-eye">// UNIVERSAL WIP INTELLIGENCE · AUDITOPS ENGINE V2</div>
  <h1 class="hero-title">Universal <em id="sector-label">WIP</em><br>Intelligence Dashboard</h1>
  <p style="font-size:.85rem;color:var(--text);margin:.5rem 0 1.2rem;max-width:560px">One engine. Any industry. Real-time percent-complete analysis, profit fade detection, and CFO-ready narratives — powered by UPCODE-DETECT-V2 and the TSM Sovereign Mesh.</p>

  <div class="sector-bar">
    <button class="sector-btn active-construction" id="btn-construction" onclick="setSector('construction')">🏗 CONSTRUCTION</button>
    <button class="sector-btn" id="btn-healthcare" onclick="setSector('healthcare')">🏥 HEALTHCARE</button>
    <button class="sector-btn" id="btn-insurance" onclick="setSector('insurance')">📋 INSURANCE</button>
  </div>
</div>

<!-- MAIN -->
<div class="main">
  <!-- LEFT COLUMN -->
  <div>
    <!-- KPI CARDS -->
    <div class="wip-cards" id="kpi-cards">
      <!-- injected by JS -->
    </div>

    <!-- WIP MATRIX TABLE -->
    <div class="wip-matrix">
      <div class="wm-head">
        <span class="wm-title" id="matrix-title">WORK IN PROGRESS MATRIX</span>
        <span class="wm-badge" id="matrix-badge" style="color:var(--amber);border-color:var(--amber)">3 ACTIVE FLAGS</span>
      </div>
      <table class="wip-table" id="wip-table">
        <!-- injected by JS -->
      </table>
    </div>

    <!-- ALERT FEED -->
    <div class="alert-feed">
      <div class="af-head" id="alert-title">ACTIVE INTELLIGENCE FLAGS</div>
      <div id="alert-items"><!-- injected --></div>
    </div>

    <!-- AI NARRATIVE -->
    <div class="ai-panel">
      <div class="ap-head">
        <span class="ap-title" id="ai-panel-title">STRATEGIST AUTO-NARRATIVE</span>
        <button class="ap-run" id="ap-run-btn" onclick="runNarrative()">⚡ GENERATE</button>
      </div>
      <div class="ap-body" id="ap-body">
        <span class="ap-placeholder">Select an entity and click GENERATE to produce a CFO-ready AI narrative for this sector.</span>
      </div>
    </div>
  </div>

  <!-- RIGHT COLUMN -->
  <div>
    <!-- ENTITY LIST -->
    <div class="alert-feed" style="margin-bottom:1rem">
      <div class="af-head" id="entity-title">ACTIVE ENTITIES</div>
      <div class="entity-list" id="entity-list"><!-- injected --></div>
    </div>

    <!-- ACTION RAIL -->
    <div class="action-rail">
      <div class="ar-head" id="action-title">QUICK ACTIONS</div>
      <div id="action-btns"><!-- injected --></div>
    </div>

    <!-- LIVE SCHEMA -->
    <div class="schema-panel">
      <div class="sp-head">UNIFIED WIP SCHEMA · ACTIVE ENTITY</div>
      <div class="sp-body" id="schema-body">
        <span style="color:var(--muted)">Select an entity to view schema.</span>
      </div>
    </div>
  </div>
</div>

<script>
// ── SECTOR DATA ─────────────────────────────────────────────────
const SECTORS = {
  construction: {
    label: 'Construction WIP',
    bodyClass: 'sector-construction',
    color: '#ffb300',
    kpis: [
      { label:'TOTAL CONTRACT VALUE', value:'$14.2M', sub:'7 active jobs', delta:'+$840K new', cls:'delta-up' },
      { label:'COSTS INCURRED', value:'$8.9M', sub:'cost-to-cost method', delta:'62.7% complete', cls:'delta-warn' },
      { label:'EARNED REVENUE', value:'$8.85M', sub:'% complete × contract', delta:'On track', cls:'delta-up' },
      { label:'OVER/UNDER BILLING', value:'-$60K', sub:'under-billed (asset)', delta:'⚠ Invoice now', cls:'delta-warn' },
      { label:'PROFIT FADE RISK', value:'$320K', sub:'3 jobs trending down', delta:'↓ Margin slipping', cls:'delta-down' },
      { label:'RETAINAGE HELD', value:'$710K', sub:'5% avg held', delta:'Release eligible: $210K', cls:'delta-up' },
    ],
    tableHeaders: ['JOB / PROJECT', '% COMPLETE', 'EARNED REV', 'BILLED TO DATE', 'VARIANCE', 'STATUS'],
    tableRows: [
      ['JOB-203 · Mesa Medical Center', 63, '$1.82M', '$1.76M', '-$60K', 'warn'],
      ['JOB-198 · Scottsdale Office Park', 88, '$3.1M', '$3.15M', '+$50K', 'good'],
      ['JOB-211 · Phoenix Distribution Hub', 41, '$2.3M', '$2.1M', '-$200K', 'bad'],
      ['JOB-187 · Tempe Retail Complex', 97, '$4.2M', '$4.22M', '+$20K', 'good'],
      ['JOB-215 · Chandler Residential', 22, '$0.9M', '$0.85M', '-$50K', 'warn'],
    ],
    alerts: [
      { sev:'CRIT', cls:'sev-crit', text:'<strong>JOB-211 Profit Fade:</strong> Labor overrun $87K above estimate at 41% complete. Projected margin: 2.1% vs bid 8.4%. Action: Issue corrective RFI and scope adjustment.' },
      { sev:'HIGH', cls:'sev-high', text:'<strong>JOB-203 Under-Billed $60K:</strong> Earned $1.82M, billed $1.76M. Invoice immediately to correct cash position. AIA G702/G703 ready to generate.' },
      { sev:'HIGH', cls:'sev-high', text:'<strong>JOB-215 Retainage Release:</strong> $210K release eligible on JOB-187 (97% complete). Submit release request to GC — 30-day window open.' },
      { sev:'MED', cls:'sev-med', text:'<strong>OSHA Readiness:</strong> JOB-211 scheduled inspection in 14 days. 3 open safety items in AuditOps. Run OSHA Compliance Audit module.' },
    ],
    entities: [
      { id:'JOB-203', name:'Mesa Medical Center', meta:'63% · $1.82M earned · Risk: HIGH', risk:'74', riskCls:'cell-bad' },
      { id:'JOB-211', name:'Phoenix Distribution Hub', meta:'41% · $2.3M earned · Risk: CRIT', risk:'91', riskCls:'cell-bad' },
      { id:'JOB-198', name:'Scottsdale Office Park', meta:'88% · $3.1M earned · Risk: LOW', risk:'18', riskCls:'cell-good' },
      { id:'JOB-187', name:'Tempe Retail Complex', meta:'97% · $4.2M earned · Risk: LOW', risk:'12', riskCls:'cell-good' },
      { id:'JOB-215', name:'Chandler Residential', meta:'22% · $0.9M earned · Risk: MED', risk:'45', riskCls:'cell-warn' },
    ],
    actions: ['Generate AIA G702/G703 Draw Request', 'Run Profit Fade Analysis — All Jobs', 'Submit Retainage Release Request', 'Export WIP Schedule to Excel', 'Push to AuditOps BNCA Pipeline', 'Run OSHA Readiness Audit'],
    narrativePrompt: (e) => `You are the TSM Construction WIP Strategist. Analyze this job: ${e.name} (${e.id}). Status: ${e.meta}. Produce a CFO-ready executive narrative covering: (1) WIP position summary with earned vs billed variance, (2) profit fade risk assessment, (3) 3 immediate actions with dollar impact, (4) 30/60/90 day cash flow outlook. Be specific with dollar amounts. Under 250 words.`,
  },

  healthcare: {
    label: 'Healthcare RCM WIP',
    bodyClass: 'sector-healthcare',
    color: '#00ff88',
    kpis: [
      { label:'TOTAL EXPECTED REIMBURSEMENT', value:'$2.8M', sub:'active encounters', delta:'April billing cycle', cls:'delta-up' },
      { label:'CLAIMS SUBMITTED', value:'$2.1M', sub:'75% of expected', delta:'$700K pending submission', cls:'delta-warn' },
      { label:'PAYER PAYMENTS RECEIVED', value:'$1.65M', sub:'collected to date', delta:'78.6% collection rate', cls:'delta-up' },
      { label:'DENIAL / AR AGING GAP', value:'$189K', sub:'14 UPCODE-DETECT flags', delta:'⚠ Correct before submission', cls:'delta-bad' },
      { label:'UPCODE-DETECT FLAGS', value:'14', sub:"99214 → 99213 corrections", delta:'-$4.2K monthly if uncorrected', cls:'delta-down' },
      { label:'DAYS IN AR', value:'52', sub:'target: 35 days', delta:'↑ 17 days over target', cls:'delta-down' },
    ],
    tableHeaders: ['ENCOUNTER / CLAIM', 'RCM STAGE', 'EXPECTED', 'COLLECTED', 'DENIAL GAP', 'STATUS'],
    tableRows: [
      ['ENC-8821 · Prior Auth Denial', 85, '$4,200', '$0', '-$4,200', 'bad'],
      ['ENC-8834 · Coding Review', 60, '$1,850', '$1,480', '-$370', 'warn'],
      ['ENC-8756 · Payer Adjudication', 90, '$6,100', '$5,490', '-$610', 'warn'],
      ['ENC-8801 · Payment Posted', 100, '$3,300', '$3,300', '$0', 'good'],
      ['ENC-8912 · Claim Scrubbing', 30, '$2,750', '$0', '-$2,750', 'bad'],
    ],
    alerts: [
      { sev:'CRIT', cls:'sev-crit', text:"<strong>UPCODE-DETECT-V2 Alert:</strong> 14 instances of '99214' found that should be coded '99213'. Estimated revenue loss: $4,200/month if uncorrected. Action: Correct coding before submission." },
      { sev:'HIGH', cls:'sev-high', text:'<strong>Prior Auth Denial — ENC-8821:</strong> $4,200 claim denied. Missing prior authorization documentation. Action: File appeal with auth reference within 30-day window.' },
      { sev:'HIGH', cls:'sev-high', text:'<strong>AR Aging Critical:</strong> DSO at 52 days vs 35-day target. 3 claims over 90 days. Westside Payer $18.4K — escalate to collections.' },
      { sev:'MED', cls:'sev-med', text:'<strong>ENC-8912 Scrubbing Hold:</strong> Claim held in scrubbing queue — missing modifier. Correct and resubmit within 48 hours to avoid timely filing denial.' },
    ],
    entities: [
      { id:'ENC-8821', name:'Prior Auth Denial', meta:'85% stage · $4,200 expected · Risk: CRIT', risk:'95', riskCls:'cell-bad' },
      { id:'ENC-8912', name:'Claim Scrubbing Hold', meta:'30% stage · $2,750 expected · Risk: HIGH', risk:'78', riskCls:'cell-bad' },
      { id:'ENC-8834', name:'Coding Review Queue', meta:'60% stage · $1,850 expected · Risk: MED', risk:'42', riskCls:'cell-warn' },
      { id:'ENC-8756', name:'Payer Adjudication', meta:'90% stage · $6,100 expected · Risk: LOW', risk:'22', riskCls:'cell-warn' },
      { id:'ENC-8801', name:'Payment Posted — Closed', meta:'100% · $3,300 collected · Risk: NONE', risk:'0', riskCls:'cell-good' },
    ],
    actions: ['Push Corrected Codes to RCM System', 'File Prior Auth Appeal — ENC-8821', 'Run UPCODE-DETECT-V2 Full Scan', 'Escalate 90+ Day Claims to Collections', 'Generate Denial Management Report', 'Export AR Aging to Controller'],
    narrativePrompt: (e) => `You are the TSM Healthcare RCM WIP Strategist. Analyze this encounter: ${e.name} (${e.id}). Status: ${e.meta}. Produce a CFO-ready executive narrative covering: (1) RCM position and denial risk, (2) UPCODE-DETECT findings if applicable, (3) 3 immediate revenue recovery actions with dollar amounts, (4) payer strategy and appeal window status. Be specific. Under 250 words.`,
  },

  insurance: {
    label: 'Insurance CIP / Reserve WIP',
    bodyClass: 'sector-insurance',
    color: '#a855f7',
    kpis: [
      { label:'TOTAL RESERVE ALLOCATED', value:'$4.1M', sub:'active claims portfolio', delta:'12 open claims', cls:'delta-up' },
      { label:'RESERVES PAID TO DATE', value:'$2.6M', sub:'63.4% of allocated reserve', delta:'3 claims over reserve', cls:'delta-warn' },
      { label:'RESERVE REMAINING', value:'$1.5M', sub:'projected settlement', delta:'On track', cls:'delta-up' },
      { label:'RESERVE VARIANCE', value:'+$340K', sub:'3 claims over-reserved', delta:'⚠ Re-evaluate liability', cls:'delta-warn' },
      { label:'FRAUD / ESCALATION FLAGS', value:'2', sub:'pattern anomaly detected', delta:'E&O risk: $840K', cls:'delta-down' },
      { label:'CYCLE TIME (AVG)', value:'47d', sub:'target: 30 days', delta:'↑ 17 days over SLA', cls:'delta-down' },
    ],
    tableHeaders: ['CLAIM ID', '% LIABILITY EST.', 'RESERVE SET', 'PAID TO DATE', 'VARIANCE', 'STATUS'],
    tableRows: [
      ['CLM-882 · Auto Liability', 40, '$85,000', '$63,750', '+$21K over-reserved', 'warn'],
      ['CLM-841 · Property Damage', 95, '$124,000', '$120,000', '-$4K under-reserved', 'good'],
      ['CLM-901 · Workers Comp', 25, '$210,000', '$157,500', '+$52K over-reserved', 'bad'],
      ['CLM-867 · Commercial GL', 78, '$340,000', '$332,000', '-$8K under-reserved', 'good'],
      ['CLM-923 · E&O Malpractice', 60, '$840,000', '$504,000', 'FRAUD FLAG', 'bad'],
    ],
    alerts: [
      { sev:'CRIT', cls:'sev-crit', text:'<strong>CLM-923 Fraud Pattern:</strong> E&O Malpractice claim — payment pattern anomaly detected. $840K reserve exposure. Action: Flag for SIU review immediately. Do not release reserve.' },
      { sev:'HIGH', cls:'sev-high', text:'<strong>CLM-882 Reserve Re-evaluation:</strong> Claim 40% complete but 75% of reserve utilized. Action: Re-evaluate liability threshold — current reserve insufficient. Recommend $25K reserve increase.' },
      { sev:'HIGH', cls:'sev-high', text:'<strong>CLM-901 Over-Reserved $52K:</strong> Workers Comp claim stagnant at 25% for 60 days. Reserve may be excessive. Action: Adjuster review and potential reserve release.' },
      { sev:'MED', cls:'sev-med', text:'<strong>Cycle Time SLA Breach:</strong> Portfolio average 47 days vs 30-day SLA target. 4 claims pending adjuster action. Escalate to claims supervisor.' },
    ],
    entities: [
      { id:'CLM-923', name:'E&O Malpractice Claim', meta:'60% · $840K reserve · Risk: CRIT', risk:'97', riskCls:'cell-bad' },
      { id:'CLM-882', name:'Auto Liability Claim', meta:'40% · $85K reserve · Risk: HIGH', risk:'82', riskCls:'cell-bad' },
      { id:'CLM-901', name:'Workers Comp Claim', meta:'25% · $210K reserve · Risk: MED', risk:'55', riskCls:'cell-warn' },
      { id:'CLM-867', name:'Commercial GL Claim', meta:'78% · $340K reserve · Risk: LOW', risk:'20', riskCls:'cell-warn' },
      { id:'CLM-841', name:'Property Damage Claim', meta:'95% · $124K reserve · Risk: LOW', risk:'8', riskCls:'cell-good' },
    ],
    actions: ['Re-Evaluate Reserve — CLM-882', 'Flag CLM-923 for SIU Review', 'Generate Premium Audit Report', 'Release Over-Reserve — CLM-901', 'Export Claims WIP to Adjuster', 'Run P&C Loss Control Analysis'],
    narrativePrompt: (e) => `You are the TSM Insurance WIP Strategist. Analyze this claim: ${e.name} (${e.id}). Status: ${e.meta}. Produce a CFO-ready executive narrative covering: (1) reserve adequacy assessment vs % liability established, (2) fraud/escalation risk if applicable, (3) 3 immediate adjuster actions with dollar impact, (4) E&O exposure and premium audit implications. Be specific. Under 250 words.`,
  },
};

// ── STATE ────────────────────────────────────────────────────────
let currentSector = 'construction';
let selectedEntity = null;

// ── SECTOR SWITCH ────────────────────────────────────────────────
function setSector(s) {
  currentSector = s;
  selectedEntity = null;
  const data = SECTORS[s];
  document.body.className = data.bodyClass;
  document.documentElement.style.setProperty('--s-color', data.color);

  // Update sector buttons
  ['construction','healthcare','insurance'].forEach(k => {
    const b = document.getElementById('btn-'+k);
    b.className = 'sector-btn' + (k === s ? ' active-'+k : '');
  });

  document.getElementById('sector-label').textContent = data.label;
  document.getElementById('hero-eye').textContent = '// UNIVERSAL WIP INTELLIGENCE · ' + data.label.toUpperCase();
  document.getElementById('tb-brand').textContent = 'TSM · SOVEREIGN MESH · ' + data.label.toUpperCase();

  renderKPIs(data);
  renderTable(data);
  renderAlerts(data);
  renderEntities(data);
  renderActions(data);
  resetNarrative();
}

function renderKPIs(data) {
  document.getElementById('kpi-cards').innerHTML = data.kpis.map(k => `
    <div class="wc">
      <div class="wc-label">${k.label}</div>
      <div class="wc-value">${k.value}</div>
      <div class="wc-sub">${k.sub}</div>
      <div class="wc-delta ${k.cls}">${k.delta}</div>
    </div>`).join('');
}

function renderTable(data) {
  const th = data.tableHeaders.map(h => `<th>${h}</th>`).join('');
  const rows = data.tableRows.map(r => {
    const pct = r[1];
    const barCls = pct >= 80 ? 'bar-good' : pct >= 50 ? 'bar-warn' : 'bar-bad';
    const varCls = r[4].startsWith('-') || r[4].includes('FLAG') ? 'cell-bad' : r[4].startsWith('+') && r[4].includes('over') ? 'cell-warn' : 'cell-good';
    const statusCls = r[5] === 'good' ? 'cell-good' : r[5] === 'warn' ? 'cell-warn' : 'cell-bad';
    return `<tr>
      <td class="cell-label">${r[0]}</td>
      <td><span class="cell-pct ${barCls === 'bar-good' ? 'cell-good' : barCls === 'bar-warn' ? 'cell-warn' : 'cell-bad'}">${pct}%</span><span class="cell-bar-wrap"><span class="cell-bar ${barCls}" style="width:${pct}%"></span></span></td>
      <td class="cell-value">${r[2]}</td>
      <td class="cell-value">${r[3]}</td>
      <td class="${varCls}" style="font-family:var(--mono);font-size:.65rem">${r[4]}</td>
      <td><span class="${statusCls}" style="font-family:var(--mono);font-size:.5rem;letter-spacing:.06em">${r[5].toUpperCase()}</span></td>
    </tr>`;
  }).join('');
  document.getElementById('wip-table').innerHTML = `<thead><tr>${th}</tr></thead><tbody>${rows}</tbody>`;
}

function renderAlerts(data) {
  document.getElementById('alert-items').innerHTML = data.alerts.map(a => `
    <div class="af-item">
      <span class="af-sev ${a.cls}">${a.sev}</span>
      <span class="af-text">${a.text}</span>
    </div>`).join('');
}

function renderEntities(data) {
  document.getElementById('entity-list').innerHTML = data.entities.map((e,i) => `
    <div class="entity" id="ent-${i}" onclick="selectEntity(${i})">
      <span class="entity-risk ${e.riskCls}" style="float:right;font-family:var(--mono);font-size:.65rem;font-weight:700">${e.risk}</span>
      <div class="entity-id">${e.id}</div>
      <div class="entity-name">${e.name}</div>
      <div class="entity-meta">${e.meta}</div>
    </div>`).join('');
}

function renderActions(data) {
  document.getElementById('action-btns').innerHTML = data.actions.map(a => `
    <button class="ar-btn" onclick="runAction('${a}')">${a}</button>`).join('');
}

function selectEntity(i) {
  const data = SECTORS[currentSector];
  selectedEntity = data.entities[i];
  document.querySelectorAll('.entity').forEach((e,j) => e.classList.toggle('selected', i===j));
  renderSchema(selectedEntity, data);
  resetNarrative();
}

function renderSchema(e, data) {
  const schema = {
    entity_metadata: { entity_id: e.id, sector: currentSector, logic_engine: 'auditops-v2-strategist' },
    financial_core: {
      total_value: data.kpis[0].value,
      percent_complete: parseInt(e.meta.match(/(\d+)%/)?.[1]||'0'),
      risk_score: parseInt(e.risk),
    },
    risk_indicators: { risk_score: parseInt(e.risk), alert_flags: ['UPCODE-DETECT-V2','WIP-VARIANCE'], narrative: '(pending AI generation)' }
  };
  const json = JSON.stringify(schema, null, 2)
    .replace(/"([^"]+)":/g, '<span class="sp-key">"$1"</span>:')
    .replace(/: "([^"]+)"/g, ': <span class="sp-str">"$1"</span>')
    .replace(/: (\d+)/g, ': <span class="sp-num">$1</span>');
  document.getElementById('schema-body').innerHTML = json;
}

function resetNarrative() {
  document.getElementById('ap-body').innerHTML = '<span class="ap-placeholder">Select an entity and click GENERATE to produce a CFO-ready AI narrative for this sector.</span>';
}

async function runNarrative() {
  if (!selectedEntity) {
    const e = SECTORS[currentSector].entities[0];
    selectedEntity = e;
    document.getElementById('ent-0').classList.add('selected');
    renderSchema(e, SECTORS[currentSector]);
  }
  const btn = document.getElementById('ap-run-btn');
  const body = document.getElementById('ap-body');
  btn.disabled = true;
  btn.textContent = 'RUNNING…';
  body.textContent = '';

  const prompt = SECTORS[currentSector].narrativePrompt(selectedEntity);

  try {
    const res = await fetch('/api/groq/stream', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'llama-3.3-70b-versatile',
        max_tokens: 400,
        messages: [
          { role: 'system', content: 'You are the TSM Sovereign Mesh WIP Strategist. Produce executive-level financial analysis. Be specific with numbers. Format with clear section labels.' },
          { role: 'user', content: prompt }
        ]
      })
    });

    if (!res.ok) {
      // fallback to non-streaming
      const d = await res.json();
      body.textContent = d.content || d.error || 'Error contacting AI engine.';
      return;
    }

    const reader = res.body.getReader();
    const dec = new TextDecoder();
    let full = '';
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      for (const line of dec.decode(value).split('\n')) {
        if (!line.startsWith('data: ')) continue;
        const d = line.slice(6).trim();
        if (d === '[DONE]') break;
        try {
          const delta = JSON.parse(d).choices?.[0]?.delta?.content || '';
          full += delta;
          body.textContent = full + '▌';
          body.scrollTop = body.scrollHeight;
        } catch {}
      }
    }
    body.textContent = full;
  } catch (err) {
    body.textContent = 'Stream error: ' + err.message;
  } finally {
    btn.disabled = false;
    btn.textContent = '⚡ GENERATE';
  }
}

function runAction(action) {
  const body = document.getElementById('ap-body');
  body.textContent = `[ACTION] ${action}\n\nInitiating via TSM Sovereign Mesh…\nRouting to: ${currentSector.toUpperCase()} node\nStatus: Processing…`;
  // Could trigger specific actions here
}

// ── INIT ─────────────────────────────────────────────────────────
setSector('construction');
</script>
</body>
</html>
