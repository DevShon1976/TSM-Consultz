{
  "rules": [
    {
      "name": "NO_BROWSER_IN_NODE",
      "deny": ["document", "window", "DOMContentLoaded"]
    },
    {
      "name": "NO_NODE_IN_BROWSER",
      "deny": ["require(", "process.", "module.exports"]
    },
    {
      "name": "SCRIPT_TAG_LIMIT",
      "threshold": 200
    }
  ]
}
